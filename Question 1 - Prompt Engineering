        "# QUESTION 1\n",
        "\n",
        "# -------------------------------------------\n",
        "# Simulated Internal Databases\n",
        "# -------------------------------------------\n",
        "\n",
        "ORDERS_DB = {\n",
        "    \"12345\": {\"status\": \"In Transit\", \"expected_delivery\": \"2026-03-02\"},\n",
        "    \"67890\": {\"status\": \"Delivered\", \"expected_delivery\": \"2026-02-25\"},\n",
        "}\n",
        "\n",
        "RETURNS_DB = {\n",
        "    \"12345\": {\"eligible\": True},\n",
        "    \"67890\": {\"eligible\": False},\n",
        "}\n",
        "\n",
        "# -------------------------------------------\n",
        "# Step 1: Intent Detection Prompt\n",
        "# -------------------------------------------\n",
        "\n",
        "def detect_intent(customer_message):\n",
        "    \"\"\"\n",
        "    Simulates an LLM prompt that detects customer intent.\n",
        "    \"\"\"\n",
        "    if \"didn’t receive\" in customer_message.lower():\n",
        "        return \"missing_order\"\n",
        "    elif \"defective\" in customer_message.lower():\n",
        "        return \"defective_item\"\n",
        "    else:\n",
        "        return \"general_inquiry\"\n",
        "\n",
        "\n",
        "# -------------------------------------------\n",
        "# Step 2: Information Gathering Prompt\n",
        "# -------------------------------------------\n",
        "\n",
        "def request_additional_info(intent):\n",
        "    if intent == \"missing_order\":\n",
        "        return \"Could you please provide your order number so I can check the status?\"\n",
        "    elif intent == \"defective_item\":\n",
        "        return \"Could you upload a photo of the defective item and provide your order number?\"\n",
        "    else:\n",
        "        return \"Could you please provide more details about your issue?\"\n",
        "\n",
        "\n",
        "# -------------------------------------------\n",
        "# Step 3: Internal Database Lookup\n",
        "# -------------------------------------------\n",
        "\n",
        "def lookup_order(order_number):\n",
        "    return ORDERS_DB.get(order_number, None)\n",
        "\n",
        "\n",
        "# -------------------------------------------\n",
        "# Step 4: Resolution Generation Prompt\n",
        "# -------------------------------------------\n",
        "\n",
        "def generate_resolution(intent, order_data):\n",
        "    if not order_data:\n",
        "        return \"I’m unable to locate that order number. Could you double-check it?\"\n",
        "\n",
        "    if intent == \"missing_order\":\n",
        "        if order_data[\"status\"] == \"In Transit\":\n",
        "            return (\n",
        "                f\"Your order is currently in transit and expected to arrive by \"\n",
        "                f\"{order_data['expected_delivery']}. I’ll monitor it for you.\"\n",
        "            )\n",
        "        elif order_data[\"status\"] == \"Delivered\":\n",
        "            return (\n",
        "                \"Your order was marked as delivered. Please check with neighbors \"\n",
        "                \"or your building office. If you still can’t locate it, \"\n",
        "                \"I can initiate a replacement.\"\n",
        "            )\n",
        "\n",
        "    if intent == \"defective_item\":\n",
        "        return (\n",
        "            \"Thank you for reporting this. I’ve initiated a replacement order \"\n",
        "            \"and emailed you a prepaid return label.\"\n",
        "        )\n",
        "\n",
        "\n",
        "# -------------------------------------------\n",
        "# Main Prompt Chain Controller\n",
        "# -------------------------------------------\n",
        "\n",
        "def customer_support_ai(customer_message, order_number=None):\n",
        "    print(\"Customer:\", customer_message)\n",
        "\n",
        "    # Step 1: Detect intent\n",
        "    intent = detect_intent(customer_message)\n",
        "    print(\"Detected Intent:\", intent)\n",
        "\n",
        "    # Step 2: Request missing info\n",
        "    if not order_number:\n",
        "        follow_up = request_additional_info(intent)\n",
        "        print(\"AI:\", follow_up)\n",
        "        return\n",
        "\n",
        "    # Step 3: Lookup order\n",
        "    order_data = lookup_order(order_number)\n",
        "\n",
        "    # Step 4: Generate resolution\n",
        "    response = generate_resolution(intent, order_data)\n",
        "    print(\"AI:\", response)\n",
        "\n",
        "\n",
        "# -------------------------------------------\n",
        "# Example Runs\n",
        "# -------------------------------------------\n",
        "\n",
        "customer_support_ai(\"I didn’t receive my order.\")\n",
        "print(\"\\n--- Providing order number ---\\n\")\n",
        "customer_support_ai(\"I didn’t receive my order.\", order_number=\"12345\")\n",
        "\n",
        "print(\"\\n----------------------------\\n\")\n",
        "\n",
        "customer_support_ai(\"The item I received is defective.\", order_number=\"12345\")"
      ]
